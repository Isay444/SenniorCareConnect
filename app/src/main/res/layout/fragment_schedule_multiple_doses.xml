<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/background_light">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/azul_principal"
        android:elevation="4dp"
        app:navigationIconTint="@color/white"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="Programar dosis"
        app:titleTextColor="@color/white"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Información de frecuencia -->
        <TextView
            android:id="@+id/tvFrequencyInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=" veces al día"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp"/>

        <!-- RecyclerView de horarios -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDoseTimes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </LinearLayout>

    <!-- Botón Continuar -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:text="@string/next"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/azul_principal"
        app:cornerRadius="28dp"/>

</LinearLayout>
