<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/card_stroke">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_light"
        android:padding="16dp">

        <!-- Icono del medicamento (lado izquierdo) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="@color/medication_icon_bg"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_stroke"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivMedicationType"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_pill"
                android:contentDescription="Tipo de medicamento"
                app:tint="@color/main_accent"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Nombre del medicamento -->
        <TextView
            android:id="@+id/tvMedicationName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="40dp"
            android:text="Medicina 1"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toEndOf="@id/cardIcon"
            app:layout_constraintTop_toTopOf="@id/cardIcon"
            app:layout_constraintEnd_toStartOf="@id/btnEdit"/>

        <!-- Dosis -->
        <TextView
            android:id="@+id/tvDosage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="10mg"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintStart_toStartOf="@id/tvMedicationName"
            app:layout_constraintTop_toBottomOf="@id/tvMedicationName"
            app:layout_constraintEnd_toStartOf="@id/btnEdit"/>

        <!-- Botón editar (esquina superior derecha) -->
        <ImageButton
            android:id="@+id/btnEdit"
            android:layout_width="48dp"
            android:layout_height="42dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_edit"
            android:contentDescription="Editar"
            app:tint="@color/main_accent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <TextView
            android:id="@+id/frequencyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:text="Frecuencia"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="@id/cardIcon"
            app:layout_constraintTop_toBottomOf="@id/cardIcon"/>

        <!-- Frecuencia (debajo del icono) -->
        <TextView
            android:id="@+id/tvFrequency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Una vez al día"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            app:layout_constraintStart_toStartOf="@id/frequencyText"
            app:layout_constraintTop_toBottomOf="@id/frequencyText"/>

        <!-- Información del cuidador (lado derecho) -->
        <TextView
            android:id="@+id/tvCaregiverName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Cuidador:María García"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/main_accent"
            android:gravity="end"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnEdit"
            app:layout_constraintStart_toEndOf="@id/tvFrequency"/>

        <!-- Próxima dosis -->
        <TextView
            android:id="@+id/tvNextDose"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:text="Próxima dosis:12/10/2025 15:00"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toEndOf="@id/tvFrequency"
            app:layout_constraintTop_toBottomOf="@id/tvCaregiverName" />

        <!-- Nombre del adulto mayor -->
        <TextView
            android:id="@+id/tvElderlyName"
            android:layout_width="296dp"
            android:layout_height="16dp"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Adulto Mayor: Nombre del adulto mayor"
            android:textColor="@color/azul_principal"
            android:textStyle="bold"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="@+id/tvNextDose"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="@+id/tvFrequency"
            app:layout_constraintTop_toBottomOf="@+id/tvFrequency" />


    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
