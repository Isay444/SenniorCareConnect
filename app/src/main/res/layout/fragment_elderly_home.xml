<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context=".ui.elderly.ElderlyHomeFragment">

    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_elderly_standard">

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hola, Adulto"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp"/>

            <!-- Tarjeta Principal Gigante - MEDICAMENTO -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMedicine"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="7"
                android:minHeight="400dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                android:layout_marginBottom="@dimen/margin_elderly_large"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="3dp"
                app:strokeColor="@color/azul_principal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding_elderly">

                    <!-- ✅ Icono de medicina DINÁMICO según tipo -->
                    <ImageView
                        android:id="@+id/ivMedicationIcon"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:layout_marginBottom="16dp"
                        android:contentDescription="Icono de medicamento"
                        android:src="@drawable/ic_medication"
                        app:tint="@color/main_secondary" />

                    <!-- Título -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:text="ES HORA DE TU MEDICAMENTO"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="@dimen/text_size_elderly_large"
                        android:textStyle="bold" />

                    <!-- Nombre del medicamento -->
                    <TextView
                        android:id="@+id/tvMedicationName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:textAlignment="center"
                        android:textColor="@color/main_secondary"
                        android:textSize="@dimen/text_size_elderly_extra_large"
                        android:textStyle="bold"
                        tools:text="Paracetamol" />

                    <!-- Dosis -->
                    <TextView
                        android:id="@+id/tvDosage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:textAlignment="center"
                        android:textColor="@android:color/black"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        tools:text="500 mg" />

                    <!-- Hora del medicamento -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvMedicationTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@android:color/black"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            tools:text="08:00" />

                    </LinearLayout>

                    <!-- Frecuencia -->
                    <TextView
                        android:id="@+id/tvMedicationFrecuency"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="32dp"
                        android:textAlignment="center"
                        android:textStyle="italic"
                        android:textColor="@color/gray_black"
                        android:textSize="20sp"
                        tools:text="1 vez al día" />

                    <!-- Botón GIGANTE "LO TOMÉ" -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTookMedication"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:backgroundTint="@color/green_one"
                        android:text="LO TOMÉ"
                        android:textSize="@dimen/text_size_elderly_large"
                        android:textStyle="bold"
                        app:cornerRadius="16dp"
                        app:elevation="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ESTADO VACÍO - Cuando NO hay medicamentos -->
            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:layout_marginBottom="@dimen/margin_elderly_large"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginBottom="24dp"
                    android:src="@drawable/ic_medicine"
                    app:tint="@color/gray_black" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="¡Todo listo!"
                    android:textAlignment="center"
                    android:textColor="@color/green_one"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No tienes medicamentos\npendientes por ahora"
                    android:textAlignment="center"
                    android:textColor="@color/gray_black"
                    android:textSize="20sp" />

            </LinearLayout>

            <!-- Citas Médicas del Día -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAppointments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:backgroundTint="@color/white"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Header con icono y título -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_medical"
                            android:background="@drawable/circle_medical_appointment"
                            android:padding="6dp"
                            app:tint="@android:color/white"
                            android:contentDescription="Citas médicas"/>

                        <TextView
                            android:id="@+id/tvAppointmentsTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:text="Citas de Hoy"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="?android:attr/textColorPrimary"/>

                        <TextView
                            android:id="@+id/tvAppointmentsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/medical_appointment_stroke"
                            android:background="@drawable/badge_medical"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:visibility="gone"/>

                    </LinearLayout>

                    <!-- RecyclerView para lista de citas -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewAppointments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:visibility="gone"/>

                    <!-- Estado vacío -->
                    <LinearLayout
                        android:id="@+id/layoutNoAppointments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="24dp"
                        android:visibility="visible">

                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:src="@drawable/ic_calendar"
                            android:alpha="0.3"
                            app:tint="@color/medical_appointment_stroke"
                            android:contentDescription="Sin citas"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="No tienes citas médicas hoy"
                            android:textSize="22sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:textAlignment="center"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!-- Floating Action Button para invitar cuidador
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabInviteCaregiver"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/margin_elderly_standard"
        android:src="@drawable/ic_invite"
        android:backgroundTint="@color/green_one"
        app:tint="@android:color/white" />-->

</androidx.coordinatorlayout.widget.CoordinatorLayout>
