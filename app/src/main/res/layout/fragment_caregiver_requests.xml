<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.elderly.CaregiverRequestsFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_elderly_standard">

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:layout_marginBottom="@dimen/margin_elderly_standard"
                android:visibility="gone" />

            <!-- Título Principal -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MIS CUIDADORES"
                android:textSize="@dimen/text_size_elderly_extra_large"
                android:textStyle="bold"
                android:textAlignment="center"
                android:textColor="@color/text_primary"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/card_stroke"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="12dp"/>

            <!-- ========== SECCIÓN: SOLICITUDES PENDIENTES ========== -->

            <!-- Layout: Sin Solicitudes Pendientes -->
            <LinearLayout
                android:id="@+id/layoutNoPendingRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/card_padding_elderly"
                android:layout_marginBottom="@dimen/margin_elderly_large"
                android:visibility="gone">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_person_add"
                    android:layout_marginBottom="16dp"
                    android:contentDescription="Sin solicitudes pendientes"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No hay solicitudes pendientes"
                    android:textSize="24sp"
                    android:textAlignment="center"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Los cuidadores que usen tu código aparecerán aquí"
                    android:textSize="18sp"
                    android:textAlignment="center"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <!-- Layout: Solicitudes Pendientes -->
            <LinearLayout
                android:id="@+id/layoutPendingRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="@dimen/margin_elderly_large"
                android:visibility="gone"
                tools:visibility="visible">

                <!-- Título de la sección -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SOLICITUDES PENDIENTES"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/status_late"
                    android:layout_marginBottom="8dp" />

                <!-- Contador -->
                <TextView
                    android:id="@+id/tvPendingCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2 solicitudes pendientes"
                    android:textSize="18sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="16dp"
                    tools:text="2 solicitudes pendientes" />

                <!-- Lista de solicitudes pendientes -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPendingRequests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="true"
                    tools:itemCount="10"
                    tools:listitem="@layout/item_caregiver_request" />

            </LinearLayout>

            <!-- ========== SECCIÓN: CUIDADORES APROBADOS ========== -->

            <!-- Layout: Sin Cuidadores Aprobados -->
            <LinearLayout
                android:id="@+id/layoutNoApprovedCaregivers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="@dimen/card_padding_elderly"
                android:layout_marginBottom="@dimen/margin_elderly_large"
                android:visibility="gone">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_people"
                    android:layout_marginBottom="16dp"
                    android:contentDescription="Sin cuidadores conectados"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No tienes cuidadores conectados"
                    android:textSize="24sp"
                    android:textAlignment="center"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aprueba solicitudes para que puedan ayudarte"
                    android:textSize="18sp"
                    android:textAlignment="center"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <!-- Layout: Cuidadores Aprobados -->
            <LinearLayout
                android:id="@+id/layoutApprovedCaregivers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Título de la sección -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✅ CUIDADORES CONECTADOS"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/status_on_time"
                    android:layout_marginBottom="8dp" />

                <!-- Contador -->
                <TextView
                    android:id="@+id/tvApprovedCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="3 cuidadores conectados"
                    android:textSize="18sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="16dp"
                    tools:text="3 cuidadores conectados" />

                <!-- Lista de cuidadores aprobados -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvApprovedCaregivers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="true"
                    tools:itemCount="3"
                    tools:listitem="@layout/item_caregiver_request" />

            </LinearLayout>

            <!-- Instrucciones
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/background_secondary"
                android:layout_marginTop="@dimen/margin_elderly_large">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/margin_elderly_standard">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ℹ️ INFORMACIÓN"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• Los cuidadores pueden ver tus medicamentos y citas\n• Reciben alertas cuando presionas el botón de emergencia\n• Puedes remover cuidadores en cualquier momento\n• Solo personas con tu código pueden solicitar acceso"
                        android:textSize="16sp"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>
            -->

        </LinearLayout>

    </ScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
