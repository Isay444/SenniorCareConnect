<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="CardStyleElderly" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
        <item name="android:layout_margin">@dimen/margin_elderly_standard</item>
        <item name="contentPadding">@dimen/card_padding_elderly</item>
    </style>

    <style name="ButtonStyleElderly" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">@dimen/button_height_elderly</item>
        <item name="android:textSize">@dimen/text_size_elderly_large</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Tema para diálogos accesibles para adultos mayores -->
    <style name="Theme_ElderlyDialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">

        <!-- Fondo del diálogo -->
        <item name="android:backgroundDimAmount">0.7</item>
        <item name="android:windowBackground">@android:color/white</item>

        <!-- Texto del título -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textSize">24sp</item>

        <!-- Texto del mensaje -->
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <!-- Botones -->
        <item name="colorPrimary">@color/green_one</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="buttonBarPositiveButtonStyle">@style/ElderlyDialogButton.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/ElderlyDialogButton.Negative</item>

    </style>

    <!-- Botón positivo (Aprobar, Aceptar) -->
    <style name="ElderlyDialogButton.Positive" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/status_on_time</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingHorizontal">24dp</item>
    </style>

    <!-- Botón negativo (Cancelar, Rechazar) -->
    <style name="ElderlyDialogButton.Negative" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingHorizontal">24dp</item>
    </style>

    <style name="TabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="textAllCaps">false</item>
    </style>

    <!-- Estilo para NumberPicker -->
    <style name="NumberPickerStyle">
        <item name="colorControlNormal">@color/main_secondary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
    </style>

    <!-- Estilo para botones de días -->
    <style name="DayButtonStyle" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginStart">2dp</item>
        <item name="android:layout_marginEnd">2dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">24dp</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:backgroundTint">@color/white</item>
        <item name="android:textColor">@color/main_secondary</item>
        <item name="strokeColor">@color/main_secondary</item>

    </style>

</resources>