<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph_add_mood_entry"
    app:startDestination="@id/selectPatientForMoodFragment">

    <!-- Paso 1: Seleccionar Paciente -->
    <fragment
        android:id="@+id/selectPatientForMoodFragment"
        android:name="com.isa.cuidadocompartidomayor.ui.diary.wizard.SelectPatientForMoodFragment"
        android:label="Seleccionar Paciente"
        tools:layout="@layout/fragment_select_patient">

        <!-- Argumentos para modo edición -->
        <argument
            android:name="moodEntryId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null"/>

        <action
            android:id="@+id/action_selectPatient_to_selectEmotions"
            app:destination="@id/selectEmotionsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <!-- Paso 2: Seleccionar Emociones -->
    <fragment
        android:id="@+id/selectEmotionsFragment"
        android:name="com.isa.cuidadocompartidomayor.ui.diary.wizard.SelectEmotionsFragment"
        android:label="Seleccionar Emociones"
        tools:layout="@layout/fragment_select_emotions">

        <argument
            android:name="elderlyId"
            app:argType="string"/>
        <argument
            android:name="elderlyName"
            app:argType="string"/>
        <argument
            android:name="moodEntryId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null"/>

        <action
            android:id="@+id/action_selectEmotions_to_selectSymptomsAndLevels"
            app:destination="@id/selectSymptomsAndLevelsFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <!-- Paso 3: Seleccionar Síntomas y Niveles -->
    <fragment
        android:id="@+id/selectSymptomsAndLevelsFragment"
        android:name="com.isa.cuidadocompartidomayor.ui.diary.wizard.SelectSymptomsAndLevelsFragment"
        android:label="Síntomas y Niveles"
        tools:layout="@layout/fragment_select_symptoms_and_levels">

        <argument
            android:name="elderlyId"
            app:argType="string"/>
        <argument
            android:name="elderlyName"
            app:argType="string"/>
        <argument
            android:name="selectedEmotions"
            app:argType="string"/>
        <argument
            android:name="moodEntryId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null"/>

        <action
            android:id="@+id/action_selectSymptomsLevels_to_addNotes"
            app:destination="@id/addMoodNotesFragment"
            app:enterAnim="@anim/slide_in_right"
            app:exitAnim="@anim/slide_out_left"
            app:popEnterAnim="@anim/slide_in_left"
            app:popExitAnim="@anim/slide_out_right"/>
    </fragment>

    <!-- Paso 4: Agregar Notas y Resumen -->
    <fragment
        android:id="@+id/addMoodNotesFragment"
        android:name="com.isa.cuidadocompartidomayor.ui.diary.wizard.AddMoodNotesFragment"
        android:label="Notas Adicionales"
        tools:layout="@layout/fragment_add_mood_notes">

        <argument
            android:name="elderlyId"
            app:argType="string"/>
        <argument
            android:name="elderlyName"
            app:argType="string"/>
        <argument
            android:name="moodData"
            app:argType="string"/>
        <argument
            android:name="moodEntryId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null"/>
    </fragment>

</navigation>
